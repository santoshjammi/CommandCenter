      "command": "entity tb_AND_GATE is\nend tb_AND_GATE;\n\narchitecture behavior of tb_AND_GATE is\n  signal A, B, Y : STD_LOGIC;\n  component AND_GATE\n    Port ( A : in STD_LOGIC;\n           B : in STD_LOGIC;\n           Y : out STD_LOGIC);\n  end component;\nbegin\n  uut: AND_GATE port map (A => A, B => B, Y => Y);\n  process\n  begin\n    A <= '0'; B <= '0'; wait for 10 ns;\n    A <= '1'; B <= '0'; wait for 10 ns;\n    A <= '0'; B <= '1'; wait for 10 ns;\n    A <= '1'; B <= '1'; wait for 10 ns;\n    wait;\n  end process;\nend behavior;",
      "description": "Create a simple testbench",
      "scenario": "Create a simple testbench",
      "language": "vhdl",
      "tags": [
        "testbench",
        "simulation",
        "testing"
      ],
      "is_curated": true,
      "man_page": ""
    },
